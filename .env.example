# ── Soundstage environment ──────────────────────────────────────────────────
# Copy to .env.local and fill in. All keys are server-side only.

# Access gate. REQUIRED in production (the app fails closed without it, since the
# URL fronts metered, paid APIs). Use a long random string. In local dev, leaving
# it unset disables the gate for convenience.
APP_ACCESS_SECRET=

# Supabase (Database + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Anon key is reserved for future client-side use; not required in v1.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI providers
GEMINI_API_KEY=your-google-ai-studio-key      # Nano Banana Pro (Gemini 3 Pro Image)
ELEVENLABS_API_KEY=your-elevenlabs-key         # voices + TTS
HEYGEN_API_KEY=your-heygen-key                 # Avatar IV video
ANTHROPIC_API_KEY=your-anthropic-key           # script assistance (Claude)

# Optional model/engine overrides (defaults shown)
# IMAGE_MODEL=gemini-3-pro-image-preview
# ELEVENLABS_TTS_MODEL=eleven_v3
# SCRIPT_MODEL=claude-sonnet-4-6
# HEYGEN_ENGINE=avatar_iv
